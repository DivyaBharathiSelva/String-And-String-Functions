pw=input("Enter your password:")
dig=0
low=0
upp=0
spl=0
space=1
length=0
if len(pw)>=8 and len(pw)<=15:
    length=1
for ch in pw:
    if ch==" ":
        space=0
    if ch.isdigit():
        dig=1
    if ch.islower():
        low=1
    if ch.isupper():
        upp=1
    if ch.isalnum()==0 and ch.isspace()==0:
        spl=1
if dig==1 and low==1 and upp==1 and spl==1 and length==1:
    print("Valid password")
else:
    print("Invalid password")
